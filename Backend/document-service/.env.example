# Este servicio lee sus variables desde el .env en la RAÍZ del proyecto.
# Docker Compose lo hace automáticamente.
#
# Si quieres correr el servicio de forma standalone (sin Docker),
# crea un .env en esta carpeta con las siguientes variables:
#
# MONGO_URI=...          (ver .env raíz)
# MONGO_DB_NAME=Lexim_db
# JWT_SECRET=...         (ver .env raíz)
# PORT=3004
# GOOGLE_CREDENTIALS_PATH=./credentials/lexim-493421-e71af6001af4.json
# DRIVE_ROOT_FOLDER_ID=1se9ekY8ULFvUu9DWsD1axrH_gW-2e3ca
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
